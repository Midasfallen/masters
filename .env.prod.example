# ============================================================================
# PRODUCTION ENV — шаблон. Скопировать в .env.prod и заполнить РЕАЛЬНЫМИ значениями.
# .env.prod НЕ коммитить (он в .gitignore). Все секреты — сильные и уникальные.
# Запуск: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================================

NODE_ENV=production
PORT=3000
API_PREFIX=api/v2
HOST=0.0.0.0

# --- PostgreSQL --- (host = имя сервиса в docker-compose.prod.yml)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=service_user
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_DATABASE=service_db

# --- JWT --- сгенерировать: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_EXPIRES_IN=7d

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- MinIO ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET=posts
MINIO_USE_SSL=false
# Публичный URL, по которому отдаются медиа (через ваш домен/CDN)
MINIO_PUBLIC_URL=https://media.yourdomain.com

# --- Meilisearch --- сгенерировать: openssl rand -base64 32
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=CHANGE_ME_meili_master_key

# --- Uploads ---
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,video/mp4

# --- CORS --- список разрешённых origin через запятую (БЕЗ пробелов/слэша в конце)
CORS_ORIGIN=https://app.yourdomain.com,https://www.yourdomain.com

# --- Rate limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# --- SMTP (реальный провайдер, не MailHog) ---
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Service Platform

# --- Frontend URL (для ссылок в письмах, напр. reset-password) ---
FRONTEND_URL=https://app.yourdomain.com
